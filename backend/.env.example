# =============================================================================
# Lexifyd backend — environment template
# Copy to .env and edit:  cp .env.example .env
# Never commit .env with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — two conceptual options (see README.md in repo root)
# -----------------------------------------------------------------------------

# Which provider name the app checks for "dynamic distractors" mode.
# - groq  : Uses Groq cloud API in services/llm_distractors.py (implemented).
# - ollama: Recognized in game.py, but llm_distractors.py is Groq-only today;
#           you still get distractors from lexifyd_dataset.json unless you add
#           Ollama HTTP calls yourself. Local 7B models are not recommended for Tamil.
LLM_PROVIDER=groq

# Groq (recommended for bundled code paths)
# Get a key: https://console.groq.com/
GROQ_API_KEY=

# Ollama (local) — base URL if you extend llm_distractors.py to call Ollama
# Example: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

DATABASE_URL=sqlite:///./lexifyd.db

# Comma-separated; must include your frontend origin
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO
